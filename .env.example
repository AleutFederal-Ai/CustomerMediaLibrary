# Copy this file to .env.local for local development.
# NEVER commit .env.local — it is excluded by .gitignore.
# NEVER put secrets in this file or in .env.local.
# All secrets are loaded at runtime from Azure Key Vault.

# Required — URI of your Azure Key Vault (GCCH)
AZURE_KEY_VAULT_URI=https://<your-vault-name>.vault.usgovcloudapi.net

# Required — must always be AzureUSGovernment
AZURE_CLOUD=AzureUSGovernment

# GCCH Microsoft Graph endpoint
GRAPH_ENDPOINT=https://graph.microsoft.us

# GCCH Entra ID token endpoint
GRAPH_TOKEN_ENDPOINT=https://login.microsoftonline.us

# Full public URL of the app — REQUIRED in production for correct magic link URLs.
# Must match the custom domain assigned to the Azure App Service (with https).
# Example: https://media.aleutfederal.com
# If unset, the app derives the URL from the incoming request host, which works
# correctly behind Azure App Service / Front Door when x-forwarded-host is set.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

NODE_ENV=development

# Azure App Service — tell the platform which port the container listens on.
# The Dockerfile exposes port 3000; without this App Service defaults to 8080.
# Set this in the App Service "Configuration > Application Settings".
WEBSITES_PORT=3000
