{
  "name": "customer-media-library",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:test": "cross-env DOCKER_DEV=true AZURE_KEY_VAULT_URI=placeholder next dev -p 3100",
    "build": "next build",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "test": "npm run test:unit",
    "test:unit": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:all": "npm run test:unit && npm run test:e2e",
    "seed": "tsx scripts/seed-dev.ts",
    "docker:up": "docker compose --env-file .env.docker up --build",
    "docker:seed": "docker compose --env-file .env.docker run --rm seed"
  },
  "dependencies": {
    "@azure/cosmos": "^4.9.1",
    "@azure/identity": "^4.13.0",
    "@azure/keyvault-certificates": "^4.10.0",
    "@azure/keyvault-secrets": "^4.10.0",
    "@azure/storage-blob": "^12.31.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "archiver": "^7.0.1",
    "iron-session": "^8.0.4",
    "next": "16.1.7",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sharp": "^0.34.5",
    "uuid": "^13.0.0"
  },
  "overrides": {
    "fast-xml-parser": "5.5.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^5.0.2",
    "@vitest/coverage-v8": "^3.2.4",
    "@types/archiver": "^7.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "cross-env": "^10.0.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite": "^7.1.7",
    "vitest": "^3.2.4"
  }
}
